# -----------------------------------------------
# Lead Intelligence Agent — Environment Variables
# Copy this file to .env and fill in your values
# -----------------------------------------------

# OpenAI API key (used by the Qualifier Agent)
OPENAI_API_KEY=sk-...

# OpenAI model to use (gpt-4o recommended for quality, gpt-3.5-turbo for cost)
OPENAI_MODEL=gpt-4o

# Apify API token (used by the Researcher Agent for web scraping)
APIPY_API_TOKEN=apify_api_...

# Google Sheets — path to your service account JSON credentials file
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Google Sheet ID (the long string in the Sheet URL)
# Example: https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SHEET_ID=your_google_sheet_id_here

# Name of the tab inside your Google Sheet that contains the company list
SHEET_TAB_NAME=Sheet1

# Column name in your sheet that contains company names (default: company_name)
COMPANY_NAME_COLUMN=company_name

# Column name that contains company website (optional but improves quality)
WEBSITE_COLUMN=website

# Max number of companies to process per run (useful for testing)
# Set to 0 to process all rows
MAX_ROWS=0

# Delay between processing each company, in seconds (avoid rate limits)
ROW_DELAY_SECONDS=2
